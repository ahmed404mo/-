generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADVISOR
  SUPER_ADMIN 
}

enum FollowUpStatus {
  OPEN
  CLOSED
  REFERRED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADVISOR)
  createdAt DateTime @default(now())

  advisorAssignments AdvisorAssignment[]
  interviews         Interview[]
  followUps          FollowUp[]
  excellenceMeetings ExcellenceMeeting[]
  probationForms     ProbationForm[]
}

model Student {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  email          String   @unique
  year           Int
  group          String
  program        String
  phone          String?
  parentPhone    String?
  createdAt      DateTime @default(now())

  interviews        Interview[]
  excellenceMeetings ExcellenceMeeting[]
  probationForms    ProbationForm[]
}

model Interview {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  advisorId   String
  advisor     User     @relation(fields: [advisorId], references: [id])
  date        DateTime @default(now())
  problem     String   @db.Text
  guidance    String   @db.Text
  situation   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  followUps   FollowUp[]
}

model FollowUp {
  id             String         @id @default(cuid())
  interviewId    String
  interview      Interview      @relation(fields: [interviewId], references: [id])
  advisorId      String
  advisor        User           @relation(fields: [advisorId], references: [id])
  sessionDate    DateTime       @default(now())
  sessionType    String         
  progress       String         @db.Text 
  recommendation String?        @db.Text
  status         FollowUpStatus @default(OPEN)
  createdAt      DateTime       @default(now())
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  advisorAssignments AdvisorAssignment[]
}

model AdvisorAssignment {
  id             String       @id @default(cuid())
  advisorId      String
  advisor        User         @relation(fields: [advisorId], references: [id])
  departmentId   String
  department     Department   @relation(fields: [departmentId], references: [id])
  groupName      String
  semester       Int
  calendarYear   Int
  createdAt      DateTime     @default(now())
  @@unique([advisorId, departmentId, groupName])
}

model ExcellenceMeeting {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  advisorId         String
  advisor           User     @relation(fields: [advisorId], references: [id])
  meetingType       String
  location          String
  kpiParticipation  Float
  kpiSatisfaction   Float
  date              DateTime @default(now())
  createdAt         DateTime @default(now())
}

model ProbationForm {
  id               String   @id @default(cuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id])
  advisorId        String
  advisor          User     @relation(fields: [advisorId], references: [id])
  level            String
  gpa              Float
  passedHours      Int
  remainingHours   Int
  absencePercentage Float
  failedCourses    String
  interventionPlan String
  status           String   @default("PENDING")
  date             DateTime @default(now())
}
model AcademicYear {
  id        String   @id @default(cuid())
  year      Int
  name      String
  createdAt DateTime @default(now())
}