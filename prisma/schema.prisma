generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== الصلاحيات ==========
enum Role {
  STUDENT
  ADVISOR
  SUPER_ADMIN 
}

// ========== حالة المتابعة ==========
enum FollowUpStatus {
  OPEN      // قيد المتابعة
  CLOSED    // تم الإغلاق
  REFERRED  // تم التحويل لوحدة/لجنة
}

// ========== المستخدمين ==========
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADVISOR)
  createdAt DateTime @default(now())

  // العلاقات
  advisorAssignments AdvisorAssignment[]
  interviews         Interview[]
  followUps          FollowUp[]
}

// ========== ملف الطالب ==========
model Student {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  email          String   @unique
  year           Int
  group          String
  program        String
  phone          String?
  parentPhone    String?
  createdAt      DateTime @default(now())

  // العلاقات
  interviews     Interview[]
}

// ========== المقابلة الإرشادية ==========
model Interview {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  advisorId   String
  advisor     User     @relation(fields: [advisorId], references: [id])
  
  date        DateTime @default(now())
  problem     String   @db.Text
  guidance    String   @db.Text
  situation   String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  followUps   FollowUp[]
}

// ========== متابعة الحالة ==========
model FollowUp {
  id             String         @id @default(cuid())
  interviewId    String
  interview      Interview      @relation(fields: [interviewId], references: [id])
  advisorId      String
  advisor        User           @relation(fields: [advisorId], references: [id])
  
  sessionDate    DateTime       @default(now())
  sessionType    String         
  progress       String         @db.Text 
  recommendation String?        @db.Text
  status         FollowUpStatus @default(OPEN)
  
  createdAt      DateTime       @default(now())
}

// ========== السنوات الدراسية ==========
model AcademicYear {
  id        String   @id @default(cuid())
  year      Int      // 1, 2, 3, 4
  name      String   // "السنة الأولى", "السنة الثانية"
  createdAt DateTime @default(now())

  advisorAssignments AdvisorAssignment[]
}

// ========== الأقسام ==========
model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  
  advisorAssignments AdvisorAssignment[]
}

// ========== توزيع المرشدين ==========
model AdvisorAssignment {
  id             String       @id @default(cuid())
  advisorId      String
  advisor        User         @relation(fields: [advisorId], references: [id])
  departmentId   String
  department     Department   @relation(fields: [departmentId], references: [id])
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  groupName      String
  semester       Int
  calendarYear   Int
  createdAt      DateTime     @default(now())

  @@unique([advisorId, departmentId, academicYearId, groupName])
}